# Claude 訂閱帳號認證（base64 編碼後的 ~/.claude/.credentials.json）
# 取得方式：base64 -i ~/.claude/.credentials.json | tr -d '\n'
CLAUDE_CREDENTIALS_B64=

# 若改用 API Key 帳號則填入此處（與 CLAUDE_CREDENTIALS_B64 擇一）
ANTHROPIC_API_KEY=

# GitHub Personal Access Token（讀取目標 repo 用）
GH_TOKEN=

# Lark / Feishu Bot 認證
# 從 Lark 開發者後台 → 應用憑證 取得
FEISHU_APP_ID=
FEISHU_APP_SECRET=
