# Claude 訂閱帳號認證（base64 編碼後的 ~/.claude/.credentials.json）
# 取得方式（Linux / macOS 共用）：base64 < ~/.claude/.credentials.json | tr -d '\n'
CLAUDE_CREDENTIALS_B64=

# 若改用 API Key 帳號則填入此處（與 CLAUDE_CREDENTIALS_B64 擇一）
ANTHROPIC_API_KEY=

# Git Personal Access Token（讀目標 repo 用；公開 repo 可留空）
# - GitHub:  https://github.com/settings/tokens（scope: repo / public_repo）
# - GitLab:  Profile → Access Tokens（scope: read_repository）
# - 其他自架：對應後台
GIT_TOKEN=

# Git HTTPS 基本認證的 username（多數 token 走 oauth2 user 即可）
# - GitHub:  任意（建議 oauth2 或 x-access-token）
# - GitLab:  oauth2
# - Bitbucket: x-token-auth
GIT_USERNAME=oauth2

# Lark / Feishu Bot 認證
# 從 Lark 開發者後台 → 應用憑證 取得
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# ── 部署 / 命名 ──
# 必填，無預設。完整 git URL，HTTPS / SSH 皆可（SSH 需自備 ~/.ssh 掛入容器，預設不支援）。
# 容器內工作目錄會用 URL 最後一段（去掉 .git）自動推導，例：
#   https://github.com/owner/repo.git           → /workspace/repo
#   https://gitlab.com/group/sub/project.git    → /workspace/project
#   https://gitea.example.com/team/svc          → /workspace/svc
#   git@github.com:owner/repo.git               → /workspace/repo（需 SSH key）
TARGET_REPO=

# 可選：覆蓋 docker compose 的 project name（影響 image/container/network 命名前綴）
# 不設則預設用 docker-compose.yml 所在目錄名
# COMPOSE_PROJECT_NAME=company-doc

# ── Lark / Feishu ──
# 國際版（預設）：https://open.larksuite.com    中國版：https://open.feishu.cn
LARK_DOMAIN=https://open.larksuite.com

# lark-mcp 容器內監聽埠（容器之間用 service DNS 通訊，不對 host 暴露）
LARK_MCP_PORT=3000

# 可選：把 lark-mcp 對外暴露（除錯用）。空字串 = 不暴露。
# 若要暴露，填一個本機未被佔用的埠並解除 docker-compose.yml 內 ports: 區段註解。
LARK_MCP_HOST_PORT=

LARK_MCP_TOOLS=preset.doc.default,minutes.v1.minute.get,im.v1.message.create,im.v1.chat.list,im.v1.chat.get,im.v1.chatMembers.get

# ── cc-connect ──
CC_LANGUAGE=zh-TW
CC_PROGRESS_STYLE=compact

# 白名單：限定誰可以使用 bot（feishu open_id，逗號分隔）
# 留空 = 所有人都能用（cc-connect 啟動時會印 WARN）
# 來源由你決定（手填 / 用腳本從其他檔案抽出寫進這裡）
# 例：CC_ALLOW_FROM=ou_aaa...,ou_bbb...,ou_ccc...
CC_ALLOW_FROM=

# 特權白名單：誰能下 /shell /dir /restart /upgrade 等命令（CC_ALLOW_FROM 的子集）
# 留空 = 特權命令全部關閉
CC_ADMIN_FROM=
