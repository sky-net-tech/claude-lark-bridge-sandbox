# syntax=docker/dockerfile:1.6
#
# 從 GitHub 開源 repo (MIT) 直接 clone hermes-agent 並 build。
# 預設拉 main，可用 build arg 指定 tag/branch/commit：
#   docker build --build-arg HERMES_REF=v0.2.0 ...

ARG HERMES_REF=main

# ---------- 1. clone source ----------
FROM debian:13.4-slim AS hermes_src
RUN apt-get update && \
    apt-get install -y --no-install-recommends git ca-certificates && \
    rm -rf /var/lib/apt/lists/*
ARG HERMES_REF
WORKDIR /src
RUN git clone --depth 1 --branch "${HERMES_REF}" \
      https://github.com/NousResearch/hermes-agent.git . && \
    rm -rf .git

# ---------- 2. shared tool images ----------
FROM ghcr.io/astral-sh/uv:0.11.6-python3.13-trixie@sha256:b3c543b6c4f23a5f2df22866bd7857e5d304b67a564f4feab6ac22044dde719b AS uv_source
FROM tianon/gosu:1.19-trixie@sha256:3b176695959c71e123eb390d427efc665eeb561b1540e82679c15e992006b8b9 AS gosu_source

# ---------- 3. final image ----------
FROM debian:13.4

ENV PYTHONUNBUFFERED=1
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/hermes/.playwright

# 系統套件 + gh CLI（為了 GitHub 操作）
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential nodejs npm python3 ripgrep ffmpeg gcc python3-dev libffi-dev \
        procps git openssh-client docker-cli tini curl ca-certificates && \
    ARCH=$(dpkg --print-architecture) && \
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg && \
    chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=${ARCH} signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list && \
    apt-get update && apt-get install -y gh && \
    rm -rf /var/lib/apt/lists/*

RUN useradd -u 10000 -m -d /opt/data hermes

COPY --from=gosu_source /gosu /usr/local/bin/
COPY --from=uv_source /usr/local/bin/uv /usr/local/bin/uvx /usr/local/bin/
RUN chmod 0755 /usr/local/bin/gosu /usr/local/bin/uv /usr/local/bin/uvx

WORKDIR /opt/hermes

# layer-cache 友善：只先複製 manifests 跑 npm install
COPY --from=hermes_src /src/package.json /src/package-lock.json ./
COPY --from=hermes_src /src/web/package.json /src/web/package-lock.json web/
COPY --from=hermes_src /src/ui-tui/package.json /src/ui-tui/package-lock.json ui-tui/
COPY --from=hermes_src /src/ui-tui/packages/hermes-ink/package.json /src/ui-tui/packages/hermes-ink/package-lock.json ui-tui/packages/hermes-ink/

RUN npm install --prefer-offline --no-audit && \
    npx playwright install --with-deps chromium --only-shell && \
    (cd web && npm install --prefer-offline --no-audit) && \
    (cd ui-tui && npm install --prefer-offline --no-audit) && \
    npm cache clean --force

# 完整原始碼（從 hermes_src clone 來，無 node_modules / .git，不需要再清過 host 殘留）
COPY --from=hermes_src --chown=hermes:hermes /src/ .

RUN cd web && npm run build && \
    cd ../ui-tui && npm run build

USER root
RUN chmod -R a+rX /opt/hermes

RUN uv venv && \
    uv pip install --no-cache-dir -e ".[all]"

ENV HERMES_WEB_DIST=/opt/hermes/hermes_cli/web_dist
ENV HERMES_HOME=/opt/data
ENV PATH="/opt/data/.local/bin:${PATH}"

VOLUME ["/opt/data"]

# entrypoint 在 docker-compose 透過 volume mount 進來
ENTRYPOINT ["/usr/bin/tini", "-g", "--", "/scripts/hermes-entrypoint.sh"]
CMD ["gateway", "run"]
